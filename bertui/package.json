{
  "name": "bertui",
  "version": "1.2.9",
  "description": "Lightning-fast React dev server powered by Bun with server islands, SSR, and partial hydration",
  "type": "module",
  "main": "./index.js",
  "types": "./types/index.d.ts",
  "bin": {
    "bertui": "./bin/bertui.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./hmr": {
      "import": "./src/client/hmr-runtime.js"
    },
    "./router": {
      "types": "./types/router.d.ts",
      "import": "./src/router/index.js"
    },
    "./config": {
      "types": "./types/config.d.ts",
      "import": "./src/config/index.js"
    },
    "./logger": {
      "import": "./src/logger/logger.js"
    },
    "./styles": "./src/styles/bertui.css",
    "./compiler": {
      "import": "./src/client/compiler.js"
    },
    "./layouts": {
      "import": "./src/layouts/index.js"
    },
    "./loading": {
      "import": "./src/loading/index.js"
    },
    "./hydration": {
      "import": "./src/hydration/index.js"
    },
    "./dev": {
      "import": "./src/server/dev-server-utils.js"
    },
    "./build": {
      "import": "./src/build.js"
    }
  },
  "files": [
    "bin",
    "src",
    "types",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun bin/bertui.js dev",
    "build": "bun bin/bertui.js build",
    "serve": "bun bin/bertui.js serve",
    "preview": "bun bin/bertui.js serve --port 5000",
    "test": "cd test-app && bun run dev"
  },
  "dependencies": {
    "elysia": "^1.0.0",
    "ernest-logger": "^2.0.0",
    "lightningcss": "^1.30.2",
    "react-refresh": "^0.14.0",
    "sharp": "^0.33.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "optionalDependencies": {
    "sass": "^1.69.5"
  },
  "keywords": [
    "react",
    "bun",
    "elysia",
    "hmr",
    "fast-refresh",
    "server-islands",
    "ssr",
    "partial-hydration",
    "seo",
    "sitemap",
    "typescript"
  ],
  "author": "Pease Ernest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BunElysiaReact/BERTUI.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}